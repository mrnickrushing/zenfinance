# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (Railway provides DATABASE_URL automatically) ---
DATABASE_URL=postgres://dev:dev@localhost:5432/zenfinance

# --- Auth (admin console) ---
# JWT_SECRET must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=
# ADMIN_SECRET gates the admin console login. Generate with: openssl rand -hex 32
# The API fails closed at startup in production if this is unset.
ADMIN_SECRET=

# --- Provider access-token encryption (app layer, AES-256-GCM) ---
# Generate with: openssl rand -hex 32. Rotating this key orphans stored tokens.
TOKEN_ENC_KEY=

# --- Transaction provider ---
# 'mock' for local dev without credentials; use 'plaid' for real linking
TRANSACTION_PROVIDER=mock
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Universal link (HTTPS) Plaid Link on iOS redirects back to after an OAuth
# institution's bank-hosted auth step. Needed in production for OAuth banks
# — virtually every major US bank. Must also be added to the allowed
# redirect URIs list in the Plaid Dashboard, and the domain needs an Apple
# App Site Association file + associated-domains entitlement on the iOS app.
# Leave unset locally -- z.string().url().optional() only skips validation
# when the key is absent, not when it's an empty string.
#PLAID_REDIRECT_URI=

# --- Apple Sign-In (iOS app) ---
APPLE_BUNDLE_ID=com.rushingtechnologies.zenfinance

# --- AI enrichment (Phase 2) ---
# 'anthropic' for real Haiku categorization, 'mock' for local dev/CI without credentials
ENRICHMENT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ENRICHMENT_MODEL=claude-haiku-4-5

# --- AI coaching briefs (Phase 3) ---
# 'anthropic' for real Sonnet briefs, 'mock' for local dev/CI (deterministic, no key).
# Shares ANTHROPIC_API_KEY with enrichment.
INSIGHT_PROVIDER=anthropic
INSIGHT_MODEL=claude-sonnet-5

# --- On-demand AI coach chat ---
# Uses compact, server-computed facts only; raw bulk transactions never reach the model.
CHAT_PROVIDER=anthropic
CHAT_MODEL=claude-sonnet-5

# --- Job queue (optional locally; set on Railway with a Redis service) ---
# When unset, sync jobs run inline — fine for dev, required for tests.
REDIS_URL=redis://localhost:6379

# --- Support email via Resend ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=zenfinance@rushingtechnologies.com
SUPPORT_EMAIL=support@rushingtechnologies.com

# --- CORS / links ---
FRONTEND_URL=https://zenfinance.rushingtechnologies.com
ADMIN_URL=https://admin.zenfinance.rushingtechnologies.com

# --- Observability (optional) ---
SENTRY_DSN=

# --- Billing / RevenueCat (Phase 5) ---
# Public iOS SDK key from RevenueCat. Safe to ship in the iOS app config.
REVENUECAT_IOS_API_KEY=
# Secret REST API key for server-side subscriber refresh. Never ship to clients.
REVENUECAT_SECRET_API_KEY=
# Set this exact value as the RevenueCat webhook Authorization header.
REVENUECAT_WEBHOOK_AUTH=
# Optional HMAC signing secret from the RevenueCat webhook integration.
REVENUECAT_WEBHOOK_SIGNING_SECRET=
REVENUECAT_ENTITLEMENT_ID=zen_coach
REVENUECAT_MONTHLY_PRODUCT_ID=com.rushingtechnologies.zenfinance.coach.monthly
REVENUECAT_ANNUAL_PRODUCT_ID=com.rushingtechnologies.zenfinance.coach.annual
