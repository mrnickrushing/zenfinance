# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (Railway provides DATABASE_URL automatically) ---
DATABASE_URL=postgres://dev:dev@localhost:5432/zenfinance

# --- Auth (admin console) ---
# JWT_SECRET must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=
# ADMIN_SECRET gates the admin console login. Generate with: openssl rand -hex 32
# The API fails closed at startup in production if this is unset.
ADMIN_SECRET=

# --- Support email via Resend ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=zenfinance@rushingtechnologies.com
SUPPORT_EMAIL=support@rushingtechnologies.com

# --- CORS / links ---
FRONTEND_URL=https://zenfinance.rushingtechnologies.com

# --- Observability (optional) ---
SENTRY_DSN=
