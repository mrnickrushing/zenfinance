{
  "name": "@zenfinance/site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "vite --mode admin",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:marketing": "tsc -p tsconfig.json --noEmit && vite build --mode marketing",
    "build:admin": "tsc -p tsconfig.json --noEmit && vite build --mode admin",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@zenfinance/shared": "*",
    "class-variance-authority": "^0.7.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.1.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
